# ─── Required for admin endpoints ──────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Never commit the actual value — set this in Vercel Dashboard > Environment Variables
ADMIN_SECRET=

# ─── Optional: Redis (recommended for production) ───────────────────────────
# Without this, the app uses in-memory cache (resets on each serverless invocation).
# Recommended: Upstash Redis (free tier) — connect via Vercel integration.
# REDIS_URL=redis://...

# ─── Optional: Vercel Cron protection ──────────────────────────────────────
# Same principle as ADMIN_SECRET — set in Vercel Dashboard.
# CRON_SECRET=
